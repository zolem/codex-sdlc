{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Orchestrate Walkthrough",
  "version": "0.1.0",
  "identifier": "com.cc-sdlc.walkthrough",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Orchestrate Walkthrough",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "Review cc-sdlc walkthroughs",
    "longDescription": "Standalone desktop app for reviewing per-phase walkthroughs produced by the cc-sdlc pipeline."
  },
  "plugins": {
    "cli": {
      "args": [
        {
          "name": "repo-path",
          "index": 1,
          "takesValue": true
        },
        {
          "name": "run",
          "short": "r",
          "takesValue": true,
          "description": "Specific run slug to open"
        }
      ],
      "subcommands": {},
      "description": "Launch the Orchestrate walkthrough viewer"
    }
  }
}
